---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="tr">
<head>
    <BaseHead title={`İnteraktif Laboratuvar | ${SITE_TITLE}`} description="Tarayıcı üzerinden SAP ve SQL simülasyonları ile anında pratik yapın." />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700;800&family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="lab-body">
    <Header />

    <!-- Arka plan hareketli ızgara ve parçacıklar -->
    <div class="lab-bg-animation" aria-hidden="true">
        <div class="grid-overlay"></div>
        <div class="moving-light light-1"></div>
        <div class="moving-light light-2"></div>
    </div>

    <main class="lab-main">
        <section class="lab-hero">
            <div class="container text-center">
                <div class="status-badge">
                    <span class="live-dot"></span> SİSTEM AKTİF — ÇALIŞMA ORTAMI HAZIR
                </div>
                <h1 class="glitch-title" data-text="İnteraktif Laboratuvar">İnteraktif Laboratuvar</h1>
                <p class="hero-subtitle">
                    Teoriyi bırakın, kodlayarak öğrenin. Kurulum gerektirmeyen sanal ortamda gerçek senaryoları test edin, sorgularınızı çalıştırın ve mimariyi anında çözün.
                </p>
            </div>
        </section>

        <section class="lab-modules">
            <div class="container module-grid">
                
                <!-- 1. MODÜL: SAP ÖĞREN -->
                <a href="/sap-ogren" class="module-card sap-module">
                    <div class="card-glow"></div>
                    <div class="card-inner">
                        <div class="module-header">
                            <div class="icon-container">
                                <i class="fa-solid fa-network-wired"></i>
                            </div>
                            <span class="version-tag">v2.0 / ERP_SIM</span>
                        </div>
                        
                        <h2>SAP Modül Simülasyonu</h2>
                        <p>
                            Sanal ERP ortamında FI, MM ve SD tablolarını (BSEG, MSEG, VBAK) canlı olarak birbirine bağlayın. Karmaşık Join işlemlerini test ederek verinin sistem içindeki akışını görselleştirin.
                        </p>
                        
                        <div class="tech-stack">
                            <span><i class="fa-solid fa-cube"></i> FI/MM/SD</span>
                            <span><i class="fa-solid fa-link"></i> Table Joins</span>
                        </div>

                        <div class="action-bar">
                            <span class="cmd-prompt">~ $ ./start_sap_lab.sh</span>
                            <span class="launch-btn">Terminali Başlat <i class="fa-solid fa-arrow-right"></i></span>
                        </div>
                    </div>
                </a>

                <!-- 2. MODÜL: SQL ÖĞREN -->
                <a href="/sql-ogren" class="module-card sql-module">
                    <div class="card-glow"></div>
                    <div class="card-inner">
                        <div class="module-header">
                            <div class="icon-container">
                                <i class="fa-solid fa-database"></i>
                            </div>
                            <span class="version-tag">v3.1 / DWH_ENGINE</span>
                        </div>
                        
                        <h2>SQL & Veri Ambarı Pratiği</h2>
                        <p>
                            Ham veriyi Bronze katmanından alıp, Silver'da temizleyerek Gold katmanında analitik raporlamaya hazır hale getirecek sorguları doğrudan yazın. Alıştığınız yönetim stüdyosu rahatlığında tarayıcı üzerinden anında sonuç alın.
                        </p>
                        
                        <div class="tech-stack">
                            <span><i class="fa-solid fa-layer-group"></i> Bronze/Silver/Gold</span>
                            <span><i class="fa-solid fa-code"></i> T-SQL</span>
                        </div>

                        <div class="action-bar">
                            <span class="cmd-prompt">~ $ ./init_sql_engine.sh</span>
                            <span class="launch-btn">Konsolu Aç <i class="fa-solid fa-arrow-right"></i></span>
                        </div>
                    </div>
                </a>

            </div>
        </section>
    </main>

    <Footer />

    <style>
        :root {
            --lab-bg: #030712;
            --panel-bg: #111827;
            --sap-color: #3b82f6;
            --sap-glow: rgba(59, 130, 246, 0.4);
            --sql-color: #10b981;
            --sql-glow: rgba(16, 185, 129, 0.4);
            --text-main: #f9fafb;
            --text-muted: #9ca3af;
            --border-color: rgba(255, 255, 255, 0.1);
            
            --font-display: 'Space Grotesk', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --font-body: 'Inter', sans-serif;
        }

        body.lab-body {
            background-color: var(--lab-bg);
            color: var(--text-main);
            font-family: var(--font-body);
            margin: 0;
            overflow-x: hidden;
            position: relative;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 10; }

        /* --- DİNAMİK ARKA PLAN --- */
        .lab-bg-animation { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; overflow: hidden; pointer-events: none; }
        .grid-overlay {
            position: absolute; width: 200vw; height: 200vh; top: -50%; left: -50%;
            background-image: 
                linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
            animation: gridMove 20s linear infinite;
        }
        @keyframes gridMove { 0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); } 100% { transform: perspective(500px) rotateX(60deg) translateY(50px) translateZ(-200px); } }

        .moving-light { position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.3; animation: float 15s infinite ease-in-out alternate; }
        .light-1 { width: 400px; height: 400px; background: var(--sap-color); top: 10%; left: 10%; }
        .light-2 { width: 500px; height: 500px; background: var(--sql-color); bottom: 10%; right: 10%; animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0, 0); } 100% { transform: translate(100px, 50px); } }

        /* --- HERO --- */
        .lab-hero { padding: 100px 0 60px; }
        
        .status-badge {
            display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-mono);
            font-size: 0.8rem; letter-spacing: 0.05em; color: #34d399; background: rgba(52, 211, 153, 0.1);
            padding: 8px 20px; border-radius: 4px; border: 1px solid rgba(52, 211, 153, 0.2);
            margin-bottom: 2rem;
        }
        .live-dot { width: 8px; height: 8px; background: #34d399; border-radius: 50%; box-shadow: 0 0 10px #34d399; animation: blink 1.5s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        .glitch-title {
            font-family: var(--font-display); font-size: clamp(3rem, 6vw, 4.5rem); font-weight: 800;
            margin: 0 0 1.5rem 0; letter-spacing: -0.02em; position: relative; display: inline-block;
        }
        
        .hero-subtitle { font-size: 1.15rem; color: var(--text-muted); max-width: 700px; margin: 0 auto; line-height: 1.6; }

        /* --- MODÜL KARTLARI --- */
        .lab-modules { padding: 40px 0 120px; }
        .module-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }

        .module-card {
            background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 16px;
            text-decoration: none; color: inherit; position: relative; overflow: hidden;
            display: flex; flex-direction: column; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform: perspective(1000px) rotateX(0deg) rotateY(0deg);
            transform-style: preserve-3d;
        }

        /* Hover efekti (Kartın 3D gibi kalkması) */
        .module-card:hover { transform: perspective(1000px) translateY(-10px) scale(1.02); z-index: 20; }
        .sap-module:hover { border-color: var(--sap-color); box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 30px var(--sap-glow); }
        .sql-module:hover { border-color: var(--sql-color); box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 30px var(--sql-glow); }

        /* Kart içi arka plan parlaması */
        .card-glow { position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 50%); opacity: 0; transition: opacity 0.4s; pointer-events: none; }
        .module-card:hover .card-glow { opacity: 1; }

        .card-inner { padding: 3rem 2.5rem; display: flex; flex-direction: column; height: 100%; position: relative; z-index: 2; }

        .module-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
        
        .icon-container { width: 70px; height: 70px; border-radius: 16px; display: flex; justify-content: center; align-items: center; font-size: 2rem; background: rgba(0,0,0,0.4); border: 1px solid var(--border-color); transition: all 0.3s; }
        .sap-module .icon-container { color: var(--sap-color); }
        .sql-module .icon-container { color: var(--sql-color); }
        .module-card:hover .icon-container { transform: scale(1.1) rotate(5deg); }
        .sap-module:hover .icon-container { border-color: var(--sap-color); box-shadow: 0 0 20px var(--sap-glow); }
        .sql-module:hover .icon-container { border-color: var(--sql-color); box-shadow: 0 0 20px var(--sql-glow); }

        .version-tag { font-family: var(--font-mono); font-size: 0.75rem; color: #6b7280; padding: 4px 10px; border: 1px solid #374151; border-radius: 4px; }

        .card-inner h2 { font-family: var(--font-display); font-size: 1.8rem; margin: 0 0 1rem 0; font-weight: 700; transition: color 0.3s; }
        .sap-module:hover h2 { color: #60a5fa; }
        .sql-module:hover h2 { color: #34d399; }

        .card-inner p { font-size: 1rem; color: var(--text-muted); line-height: 1.7; margin: 0 0 2rem 0; flex-grow: 1; }

        .tech-stack { display: flex; gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
        .tech-stack span { font-family: var(--font-mono); font-size: 0.8rem; color: #d1d5db; display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.03); padding: 6px 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05); }

        .action-bar { display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.4); padding: 1rem 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); margin-top: auto; }
        .cmd-prompt { font-family: var(--font-mono); font-size: 0.85rem; color: #6b7280; }
        .launch-btn { font-family: var(--font-display); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; transition: gap 0.2s; }
        .sap-module .launch-btn { color: var(--sap-color); }
        .sql-module .launch-btn { color: var(--sql-color); }
        .module-card:hover .launch-btn { gap: 12px; }

        /* --- MOBİL UYUM --- */
        @media (max-width: 992px) {
            .module-grid { grid-template-columns: 1fr; max-width: 600px; margin: 0 auto; }
        }
        @media (max-width: 600px) {
            .action-bar { flex-direction: column; align-items: flex-start; gap: 1rem; }
            .card-inner { padding: 2rem 1.5rem; }
        }
    </style>
</body>
</html>