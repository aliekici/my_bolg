<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SAP | İnteraktif Öğren</title>

<script src="https://cdn.tailwindcss.com" is:inline></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js" crossorigin="anonymous" is:inline></script>

<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          pixel: ['"Press Start 2P"', 'cursive'],
          sans: ['Outfit', 'sans-serif'],
        },
        colors: {
          bg: '#0a0e1a',
          panel: '#111827',
          panel2: '#161f30',
          border: '#232f46',
          neon: '#39ff88',
          neonBlue: '#4fd6ff',
          neonPink: '#ff5fa2',
          gold: '#ffc84a',
          sapBlue: '#008fd3',
        },
        boxShadow: {
          pixel: '4px 4px 0px 0px rgba(0,0,0,0.5)',
          neon: '0 0 12px rgba(57,255,136,0.55)',
          sapNeon: '0 0 12px rgba(0,143,211,0.55)',
        },
      },
    },
  };
</script>

<style is:global>
  body {
    background-color: #0a0e1a;
    background-image:
      radial-gradient(circle at 15% 10%, rgba(0,143,211,0.08), transparent 35%),
      radial-gradient(circle at 85% 0%, rgba(79,214,255,0.08), transparent 35%);
  }

  code {
    background-color: #161f30 !important;
    color: #4fd6ff !important;
    padding: 2px 5px;
    border-radius: 4px;
    font-family: monospace;
    font-weight: bold;
  }

  .pixel-corners {
    clip-path: polygon(
      0px 8px, 8px 8px, 8px 0px,
      calc(100% - 8px) 0px, calc(100% - 8px) 8px, 100% 8px,
      100% calc(100% - 8px), calc(100% - 8px) calc(100% - 8px), calc(100% - 8px) 100%,
      8px 100%, 8px calc(100% - 8px), 0px calc(100% - 8px)
    );
  }

  .btn-pixel {
    box-shadow: 4px 4px 0px 0px #04321a;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
  }
  .btn-pixel-blue {
    box-shadow: 4px 4px 0px 0px #003a57;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
  }
  .btn-pixel-gold {
    box-shadow: 4px 4px 0px 0px #664d00;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
  }
  .btn-pixel:active, .btn-pixel-blue:active, .btn-pixel-gold:active {
    transform: translate(4px, 4px);
    box-shadow: 0px 0px 0px 0px transparent;
  }

  .scanline-badge {
    background-image: repeating-linear-gradient(
      45deg,
      rgba(0,143,211,0.12) 0px,
      rgba(0,143,211,0.12) 2px,
      transparent 2px,
      transparent 6px
    );
  }

  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: #0a0e1a; }
  ::-webkit-scrollbar-thumb { background: #232f46; border-radius: 8px; }

  .glow-text { text-shadow: 0 0 10px rgba(0,143,211,0.6); }
  .exercise-row:hover { background-color: #1b2436; cursor: pointer; }

  .modal-overlay { display: none; }
  .modal-overlay.active { display: flex; }
  .code-editor { font-family: 'Courier New', Courier, monospace; font-weight: bold; font-size: 1.2rem; text-transform: uppercase; }

  #editor-container {
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .custom-scroll::-webkit-scrollbar { width: 8px; }
  .custom-scroll::-webkit-scrollbar-thumb { background: #232f46; border-radius: 6px; }

  .tf-input, .tf-select {
    width: 100%;
    background: #0a0e1a;
    border: 1px solid #232f46;
    color: #fff;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    outline: none;
  }
  .tf-input:focus, .tf-select:focus { border-color: #008fd3; }
  .tf-label { font-size: 10px; color: #8b96ab; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }

  table.se16n-table th, table.se16n-table td { white-space: nowrap; }

  /* ============================= CLASSIC SAP GUI REPLICA ============================= */
  .sap-window {
    font-family: Arial, Tahoma, "Segoe UI", sans-serif;
    color: #000;
    background: #eceff1;
    border: 1px solid #0a3d67;
  }
  .sap-titlebar {
    background: linear-gradient(180deg, #5b93c9 0%, #2f6bab 45%, #0e4a82 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 6px;
    font-size: 12px;
    font-weight: bold;
    text-shadow: 0 1px 1px rgba(0,0,0,0.35);
  }
  .sap-titlebar .sap-title-icons { display: flex; gap: 3px; }
  .sap-titlebar .win-btn {
    width: 17px; height: 15px;
    background: linear-gradient(180deg, #f5f5f5, #c8c8c8);
    border: 1px solid #5c6672;
    color: #000;
    font-size: 9px;
    font-weight: bold;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
    text-shadow: none;
  }
  .sap-menubar {
    background: #ece9d8;
    border-bottom: 1px solid #aca899;
    display: flex;
    gap: 14px;
    padding: 3px 8px;
    font-size: 11px;
    color: #000;
  }
  .sap-menubar span { cursor: default; padding: 1px 3px; }
  .sap-menubar span:hover { background: #316ac5; color: #fff; }
  .sap-toolbar {
    background: #ece9d8;
    border-bottom: 1px solid #aca899;
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 3px 5px;
  }
  .sap-tool-btn {
    width: 25px; height: 23px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid transparent;
    border-radius: 2px;
    color: #2b2b2b;
    font-size: 12px;
    background: transparent;
    cursor: pointer;
  }
  .sap-tool-btn:hover { border-color: #7fa8d9; background: #dcebfb; }
  .sap-tool-btn:active { background: #b8d3f5; }
  .sap-tool-sep { width: 1px; height: 20px; background: #b7b39f; margin: 0 4px; }
  .sap-tabstrip { display: flex; gap: 2px; background: #c8c4b8; padding: 6px 6px 0; flex-wrap: wrap; }
  .sap-tab {
    padding: 5px 14px;
    font-size: 11px;
    font-weight: bold;
    background: #d4d0c8;
    border: 1px solid #8c8c8c;
    border-bottom: none;
    color: #565656;
    position: relative;
    top: 1px;
    cursor: pointer;
  }
  .sap-tab:hover { background: #dcd8cc; }
  .sap-tab.active { background: #eceff1; color: #000; border-bottom: 1px solid #eceff1; top: 0; }
  .sap-body { background: #eceff1; border-top: 1px solid #fff; padding: 14px; }
  .sap-groupbox {
    border: 1px solid #9c9c9c;
    padding: 14px 12px 12px;
    margin-bottom: 14px;
    position: relative;
    background: #eceff1;
  }
  .sap-groupbox .gb-label {
    position: absolute;
    top: -9px; left: 10px;
    background: #eceff1;
    padding: 0 6px;
    font-size: 11px;
    font-weight: bold;
    color: #0a3d67;
  }
  .sap-field-label { font-size: 11px; color: #000; margin-bottom: 2px; display: block; }
  .sap-required-mark { color: #b30000; font-weight: bold; }
  .sap-field-input {
    border: 1px solid #6b6b6b;
    background: #fff;
    padding: 3px 5px;
    font-size: 12px;
    width: 100%;
    height: 23px;
    color: #000;
  }
  .sap-field-input:focus { outline: 2px solid #316ac5; outline-offset: -1px; }
  .sap-field-required .sap-field-input { background: #ffffcc; }
  select.sap-field-input { height: 23px; }
  .sap-btn {
    background: linear-gradient(180deg, #fefefe, #d4d0c8);
    border: 1px solid #6b6b6b;
    box-shadow: inset 1px 1px 0 #fff, inset -1px -1px 0 #808080;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: bold;
    color: #000;
    cursor: pointer;
  }
  .sap-btn:active { box-shadow: inset -1px -1px 0 #fff, inset 1px 1px 0 #808080; }
  .sap-statusbar {
    background: #ece9d8;
    border-top: 1px solid #aca899;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px;
    font-size: 11px;
    color: #333;
  }
  table.sap-alv {
    border-collapse: collapse;
    width: 100%;
    font-size: 11px;
    font-family: Arial, sans-serif;
    color: #000;
  }
  table.sap-alv th {
    background: linear-gradient(180deg, #f5f5f5, #dcdcdc);
    border: 1px solid #b8b8b8;
    padding: 3px 6px;
    text-align: left;
    font-weight: bold;
    white-space: nowrap;
  }
  table.sap-alv td {
    border: 1px solid #d8d8d8;
    padding: 2px 6px;
    white-space: nowrap;
  }
  table.sap-alv tbody tr:nth-child(even) td { background: #f2f6fc; }
  table.sap-alv tbody tr:hover td { background: #d9ebfc; }
</style>
</head>

<body class="bg-bg text-gray-200 font-sans antialiased">

<header class="sticky top-0 z-50 bg-bg/90 backdrop-blur border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-sapBlue pixel-corners flex items-center justify-center">
          <i class="fa-solid fa-server text-white text-sm"></i>
        </div>
        <span class="font-pixel text-xs sm:text-sm text-white">SAP Eğitim Simülatörü</span>
      </div>

      <a href="/" class="btn-pixel-blue bg-panel2 text-neonBlue border border-sapBlue/40 font-bold text-xs px-4 py-2.5 pixel-corners hover:brightness-110 flex items-center gap-2">
        <i class="fa-solid fa-arrow-left-long"></i> Geri Dön
      </a>
    </div>
  </div>
</header>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-10">
  <div class="flex flex-col items-start">
    <span class="scanline-badge border border-sapBlue/40 text-sapBlue font-pixel text-[9px] px-3 py-2 pixel-corners mb-6">
      MODULES: MM | SD | FI
    </span>
    <h1 class="font-pixel text-4xl sm:text-5xl md:text-6xl text-white glow-text mb-4 leading-tight">SAP ERP<br>T-Code Bootcamp</h1>
    <p class="text-gray-400 text-base sm:text-lg max-w-2xl mb-6">
      Kursiyerler için hazırlanmış uçtan uca ERP simülasyonu. Doğru T-Code'u girerek gerçek bir SAP ekranı gibi işlem formunu aç, kendi verini üret, kaydet — ve verinin arka planda hangi tablolara hangi alanlarla yazıldığını canlı olarak gör. Belgeler birbirine bağlıdır: yarattığın malzeme ve siparişler bir sonraki adımda karşına çıkar.
    </p>
  </div>
</section>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
  <div class="flex flex-col lg:flex-row gap-8">

    <div class="w-full lg:w-[65%] flex flex-col gap-6">
      <div class="bg-panel border border-border pixel-corners overflow-hidden shadow-pixel">
        <div class="flex items-center justify-between px-5 py-4 border-b border-border bg-gradient-to-r from-panel to-panel2">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-sapBlue/20 pixel-corners flex items-center justify-center text-sapBlue"><i class="fa-solid fa-boxes-stacked text-sm"></i></div>
            <h2 class="font-pixel text-xs sm:text-sm text-white m-0">1. Malzeme Yönetimi (MM)</h2>
          </div>
        </div>
        <div class="divide-y divide-border" id="chapter-1-container"></div>
      </div>

      <div class="bg-panel border border-border pixel-corners overflow-hidden shadow-pixel">
        <div class="flex items-center justify-between px-5 py-4 border-b border-border bg-gradient-to-r from-panel to-panel2">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-neon/20 pixel-corners flex items-center justify-center text-neon"><i class="fa-solid fa-truck-fast text-sm"></i></div>
            <h2 class="font-pixel text-xs sm:text-sm text-white m-0">2. Satış ve Dağıtım (SD)</h2>
          </div>
        </div>
        <div class="divide-y divide-border" id="chapter-2-container"></div>
      </div>

      <div class="bg-panel border border-border pixel-corners overflow-hidden shadow-pixel">
        <div class="flex items-center justify-between px-5 py-4 border-b border-border bg-gradient-to-r from-panel to-panel2">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-gold/20 pixel-corners flex items-center justify-center text-gold"><i class="fa-solid fa-file-invoice-dollar text-sm"></i></div>
            <h2 class="font-pixel text-xs sm:text-sm text-white m-0">3. Finans & Tablolar (FI/BI)</h2>
          </div>
        </div>
        <div class="divide-y divide-border" id="chapter-3-container"></div>
      </div>
    </div>

    <aside class="w-full lg:w-[35%]">
      <div class="lg:sticky lg:top-24 flex flex-col gap-6">
        <div class="bg-panel border border-border pixel-corners p-5 flex flex-col items-center text-center">
          <img src="https://ui-avatars.com/api/?name=Key+User&background=008fd3&color=fff&size=80" alt="user avatar" class="w-16 h-16 pixel-corners mb-3" />
          <span class="font-semibold text-white text-sm mb-1">Key User Adayı</span>
          <span class="font-pixel text-[9px] text-sapBlue mb-4">MODÜL: TÜMÜ</span>
          <button onclick="resetProgress()" class="text-gray-500 hover:text-neonPink text-xs mt-2 underline cursor-pointer">Sistemi Sıfırla (/nEX)</button>
        </div>

        <div class="bg-panel border border-border pixel-corners p-5 shadow-pixel">
          <h3 class="font-pixel text-[10px] text-white mb-4">EĞİTİM İLERLEMESİ</h3>
          <div class="w-full h-3 bg-panel2 border border-border pixel-corners mb-3 overflow-hidden relative">
            <div id="progress-bar" class="h-full bg-sapBlue transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
            <span>Senaryolar</span>
            <span id="ex-text" class="text-gray-200 font-semibold">0 / 13</span>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400">
            <span>SAP Puanı</span>
            <span id="xp-text" class="text-gray-200 font-semibold">0 / 650</span>
          </div>
        </div>

        <div class="bg-panel border border-border pixel-corners p-5 shadow-pixel">
          <h3 class="font-pixel text-[10px] text-white mb-4 flex items-center gap-2">
            <i class="fa-solid fa-database text-sapBlue"></i> CANLI VERİTABANI
          </h3>
          <div id="db-summary" class="text-[11px] text-gray-400 space-y-1 font-mono max-h-64 overflow-y-auto custom-scroll pr-1"></div>
        </div>
      </div>
    </aside>

  </div>
</main>

<div id="lesson-modal" class="modal-overlay fixed inset-0 z-[100] bg-bg/95 backdrop-blur-md items-center justify-center p-2 sm:p-6">
  <div class="bg-panel border-2 border-border pixel-corners w-full max-w-6xl h-full sm:h-[95vh] flex flex-col md:flex-row overflow-hidden relative shadow-sapNeon">

    <button onclick="closeLesson()" class="absolute top-4 right-4 bg-bg border border-border text-gray-400 hover:text-white hover:border-white z-20 w-8 h-8 pixel-corners flex items-center justify-center">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="w-full md:w-5/12 bg-[#0a0e1a] border-r border-border p-6 sm:p-8 overflow-y-auto flex flex-col gap-6 custom-scroll">
       <div class="flex items-center gap-3 border-b border-border pb-4">
         <div id="lesson-number-badge" class="w-8 h-8 bg-sapBlue/20 pixel-corners flex items-center justify-center text-sapBlue font-pixel text-xs"></div>
         <h2 id="lesson-title" class="font-pixel text-sm sm:text-base text-white leading-relaxed m-0"></h2>
       </div>
       <div id="lesson-content" class="text-gray-300 text-sm sm:text-base leading-relaxed space-y-5 font-sans">
       </div>
    </div>

    <div class="w-full md:w-7/12 flex flex-col bg-panel2 h-full">
       <div class="flex-none p-4 flex flex-col gap-2 relative border-b border-border">
          <div class="flex justify-between items-center text-xs text-gray-400 font-pixel mb-1">
             <span><i class="fa-solid fa-terminal text-sapBlue"></i> Komut Alanı (OK-Code)</span>
             <span id="live-status" class="hidden text-[10px]"></span>
          </div>
          <div id="editor-container" class="flex bg-white border-2 border-border pixel-corners overflow-hidden items-center px-4 h-12">
            <span class="text-black font-bold mr-2">✔</span>
            <input type="text" id="sql-editor" oninput="checkLiveCode()" onkeypress="handleEnter(event)" class="w-full bg-transparent text-black code-editor focus:outline-none" spellcheck="false" autocomplete="off" placeholder="T-Code Girin... (Örn: MM01)"/>
          </div>
       </div>

       <div class="p-4 bg-panel border-b border-border flex justify-between items-center z-10 flex-wrap gap-3">
          <div class="flex gap-3">
            <button onclick="runCode()" class="btn-pixel-blue bg-sapBlue text-white font-bold text-xs sm:text-sm px-6 py-2.5 pixel-corners hover:brightness-110 flex items-center gap-2">
              <i class="fa-solid fa-play"></i> Ekranı Aç (Enter)
            </button>
            <button onclick="showHint()" class="btn-pixel-gold bg-gold text-bg font-bold text-xs sm:text-sm px-4 py-2.5 pixel-corners hover:brightness-110 flex items-center gap-2">
              <i class="fa-solid fa-lightbulb"></i> T-Code Unuttum
            </button>
          </div>

          <button id="next-btn" onclick="nextLesson()" class="hidden btn-pixel bg-neon text-bg font-bold text-xs sm:text-sm px-6 py-2.5 pixel-corners hover:brightness-110">
            Sonraki Senaryo <i class="fa-solid fa-arrow-right"></i>
          </button>
       </div>

       <div class="flex-1 bg-[#111827] p-4 overflow-y-auto font-sans text-xs sm:text-sm custom-scroll flex flex-col gap-2" id="console-output">
          <span class="text-gray-500 font-mono">> SAP Sistemine Bağlanıldı (Client 100). Bekleniyor...</span>
       </div>
    </div>
  </div>
</div>

<script is:inline>
  /* ============================= STATE ============================= */
  let currentLesson = 1;
  let xp = 0;
  let completedLessons = new Set();
  const STORAGE_KEY = "sap_bootcamp_progress_v2";

  function defaultDB() {
    return { MARA: [], MARC: [], EKKO: [], EKPO: [], MKPF: [], MSEG: [], MARD: [],
             VBAK: [], VBAP: [], LIKP: [], LIPS: [], VBRK: [], VBRP: [], BKPF: [], BSEG: [] };
  }
  function defaultCounters() {
    return { mat: 10004534, po: 4500023199, matdoc: 5000012431, so: 20004561,
             dlv: 80001235, bill: 90045122, miro: 5105600010, fb: 100000456 };
  }
  let db = defaultDB();
  let counters = defaultCounters();

  const TABLE_META = {
    MARA: { desc: 'Genel Malzeme Verileri', cols: ['MATNR','MAKTX','MTART','MEINS','MATKL','BISMT'] },
    MARC: { desc: 'Fabrika Verileri (Malzeme)', cols: ['MATNR','WERKS','LGORT','NTGEW'] },
    EKKO: { desc: 'Satınalma Belgesi Başlık', cols: ['EBELN','LIFNR','BUKRS','WAERS','BEDAT'] },
    EKPO: { desc: 'Satınalma Belgesi Kalem', cols: ['EBELN','EBELP','MATNR','MENGE','NETPR','WERKS'] },
    MKPF: { desc: 'Malzeme Belgesi Başlık', cols: ['MBLNR','BLDAT','BUDAT'] },
    MSEG: { desc: 'Malzeme Belgesi Segment', cols: ['MBLNR','ZEILE','MATNR','WERKS','MENGE','BWART'] },
    MARD: { desc: 'Depo Yeri Stok Verisi', cols: ['MATNR','WERKS','LGORT','LABST'] },
    VBAK: { desc: 'Satış Belgesi Başlık', cols: ['VBELN','VKORG','KUNNR','VTWEG','SPART'] },
    VBAP: { desc: 'Satış Belgesi Kalem', cols: ['VBELN','POSNR','MATNR','KWMENG','NETPR'] },
    LIKP: { desc: 'Teslimat Başlık', cols: ['VBELN','VSTEL','LFDAT'] },
    LIPS: { desc: 'Teslimat Kalem', cols: ['VBELN','POSNR','MATNR','LFIMG','VGBEL'] },
    VBRK: { desc: 'Fatura Başlık', cols: ['VBELN','FKART','NETWR','WAERK'] },
    VBRP: { desc: 'Fatura Kalem', cols: ['VBELN','POSNR','MATNR','FKIMG','NETWR'] },
    BKPF: { desc: 'Muhasebe Belgesi Başlık', cols: ['BELNR','BUKRS','BLART','BUDAT'] },
    BSEG: { desc: 'Muhasebe Belgesi Kalem', cols: ['BELNR','BUZEI','HKONT','SHKZG','WRBTR'] },
  };

  function todayStr() { return new Date().toISOString().slice(0, 10); }

  /* ============================= LESSONS ============================= */
  const lessonsData = [
    // BÖLÜM 1: MM (MALZEME YÖNETİMİ)
    {
      id: 1, ch: 1, name: "Malzeme Yaratma (Material Master)", title: "1. MM01 - Malzeme Yaratma",
      content: `<span class="inline-block text-[9px] font-pixel text-sapBlue border border-sapBlue/40 px-2 py-1 pixel-corners mb-1">MODÜL: MM &nbsp;|&nbsp; KATEGORİ: ANA VERİ (MASTER DATA)</span>
                <p>SAP sisteminde her şey bir ana veri (Master Data) ile başlar. Bir ürün alıp satabilmek için önce sistemde onu tanımlamalısın. <b>MM01</b>, gerçek SAP projelerinde en çok kullanılan işlem kodlarından biridir; çünkü stok, satınalma, üretim ve satış — hepsi bir malzeme kaydına bağlıdır.</p>
