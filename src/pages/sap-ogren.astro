              <button onclick="showStockOverview()" class="sap-btn flex items-center gap-2">
                <i class="fa-solid fa-magnifying-glass"></i> Stokları Göster (F8)
              </button>
            </div>
          </div>
          <div id="mmbe-result"></div>
        </div>
        <div class="sap-statusbar">
          <i class="fa-regular fa-circle text-gray-400"></i>
          <span>Hazır</span>
        </div>
     </div>
    `;
  }

  function showStockOverview() {
    const plantFilter = document.getElementById('mmbe-plant').value;
    const resDiv = document.getElementById('mmbe-result');
    let rows = db.MARD.map(m => {
      const mara = db.MARA.find(a => String(a.MATNR) === String(m.MATNR));
      return { MATNR: m.MATNR, MAKTX: mara ? mara.MAKTX : '-', WERKS: m.WERKS, LGORT: m.LGORT, LABST: m.LABST, MEINS: mara ? mara.MEINS : '' };
    });
    if (plantFilter) rows = rows.filter(r => String(r.WERKS) === String(plantFilter));

    if (rows.length === 0) {
      resDiv.innerHTML = `<div class="sap-window pixel-corners overflow-hidden">
        <div class="px-3 py-3 text-[#333] text-sm bg-[#fff9d6] border-b border-[#d8c96a] flex items-center gap-2">
          <i class="fa-solid fa-triangle-exclamation text-[#a8860a]"></i> Stok verisi bulunamadı. Önce MIGO ile bir mal girişi yapmalısın.
        </div>
      </div>`;
      return;
    }

    resDiv.innerHTML = `
      <div class="sap-window pixel-corners overflow-hidden">
        <div class="sap-toolbar" style="justify-content:space-between;">
          <span class="text-[11px] font-bold text-gray-700">Serbest Kullanılabilir Stok</span>
          <span class="text-[10px] text-gray-600">${rows.length} Malzeme Bulundu</span>
        </div>
        <div class="overflow-x-auto">
          <table class="sap-alv">
            <thead><tr><th>Malzeme</th><th>Açıklama</th><th>Fabrika</th><th>Depo Yeri</th><th style="text-align:right;">Stok Miktarı</th><th>Birim</th></tr></thead>
            <tbody>${rows.map(r => `<tr><td>${r.MATNR}</td><td>${r.MAKTX}</td><td>${r.WERKS}</td><td>${r.LGORT}</td><td style="text-align:right;">${r.LABST}</td><td>${r.MEINS}</td></tr>`).join('')}</tbody>
          </table>
        </div>
      </div>
    `;

    if (!completedLessons.has(11)) {
      completedLessons.add(11);
      xp += 50;
      saveProgress();
      updateProgressUI();
      updateDbSummary();
      resDiv.innerHTML += `<div class="text-gold font-pixel text-xs mt-4 block text-center bg-panel2 p-3 pixel-corners border border-gold/30">✨ TEBRİKLER! +50 SAP PUANI! ✨</div>`;
      document.getElementById('next-btn').classList.remove('hidden');
    }
  }

  /* ============================= FBL3N - G/L BALANCE SCREEN ============================= */
  function renderGLBalanceScreen() {
    const consoleOut = document.getElementById('console-output');
    consoleOut.innerHTML = `
     <div class="sap-window pixel-corners overflow-hidden">
        <div class="sap-titlebar">
          <span><i class="fa-solid fa-scale-balanced mr-1"></i> FBL3N - G/L Hesap Kalemleri</span>
          <div class="sap-title-icons">
            <span class="win-btn">_</span><span class="win-btn">&#9633;</span><span class="win-btn">&times;</span>
          </div>
        </div>
        <div class="sap-menubar">
          <span>Program</span><span>Düzenle</span><span>Görüntüle</span><span>Ortam</span><span>Yardım</span>
        </div>
        <div class="sap-toolbar">
          <button type="button" class="sap-tool-btn" onclick="showGLBalance()" title="Çalıştır (F8)"><i class="fa-solid fa-play"></i></button>
          <div class="sap-tool-sep"></div>
          <button type="button" class="sap-tool-btn" title="Geri"><i class="fa-solid fa-arrow-left"></i></button>
          <button type="button" class="sap-tool-btn" title="Çık"><i class="fa-solid fa-door-open"></i></button>
        </div>
        <div class="sap-body">
          <div class="sap-groupbox">
            <span class="gb-label">Seçim Ekranı</span>
            <div class="flex gap-3 items-end flex-wrap pt-1">
              <div class="flex flex-col gap-0.5">
                <label class="sap-field-label">Şirket Kodu</label>
                <select id="fbl3n-bukrs" class="sap-field-input" style="min-width:220px;">
                  <option value="">-- Tümü --</option>
                  <option value="1000">1000 — Ana Şirket</option>
                </select>
              </div>
              <button onclick="showGLBalance()" class="sap-btn flex items-center gap-2">
                <i class="fa-solid fa-magnifying-glass"></i> Çalıştır (F8)
              </button>
            </div>
          </div>
          <div id="fbl3n-result"></div>
        </div>
        <div class="sap-statusbar">
          <i class="fa-regular fa-circle text-gray-400"></i>
          <span>Hazır</span>
        </div>
     </div>
    `;
  }

  function showGLBalance() {
    const bukrsFilter = document.getElementById('fbl3n-bukrs').value;
    const resDiv = document.getElementById('fbl3n-result');

    let segRows = db.BSEG;
    if (bukrsFilter) {
      const belnrsInScope = new Set(db.BKPF.filter(b => String(b.BUKRS) === String(bukrsFilter)).map(b => b.BELNR));
      segRows = segRows.filter(s => belnrsInScope.has(s.BELNR));
    }

    if (segRows.length === 0) {
      resDiv.innerHTML = `<div class="sap-window pixel-corners overflow-hidden">
        <div class="px-3 py-3 text-[#333] text-sm bg-[#fff9d6] border-b border-[#d8c96a] flex items-center gap-2">
          <i class="fa-solid fa-triangle-exclamation text-[#a8860a]"></i> Muhasebe kaydı bulunamadı. Önce MIRO veya FB50 ile bir kayıt oluşturmalısın.
        </div>
      </div>`;
      return;
    }

    const byAccount = {};
    segRows.forEach(s => {
      if (!byAccount[s.HKONT]) byAccount[s.HKONT] = { debit: 0, credit: 0, count: 0 };
      const amt = Number(s.WRBTR) || 0;
      if (s.SHKZG === 'S') byAccount[s.HKONT].debit += amt; else byAccount[s.HKONT].credit += amt;
      byAccount[s.HKONT].count++;
    });
    const accountRows = Object.keys(byAccount).map(acc => {
      const d = byAccount[acc];
      return { HKONT: acc, KALEM: d.count, BORC: d.debit.toFixed(2), ALACAK: d.credit.toFixed(2), BAKIYE: (d.debit - d.credit).toFixed(2) };
    });

    resDiv.innerHTML = `
      <div class="sap-window pixel-corners overflow-hidden">
        <div class="sap-toolbar" style="justify-content:space-between;">
          <span class="text-[11px] font-bold text-gray-700">Hesap Bazında Bakiye (Toplulaştırılmış)</span>
          <span class="text-[10px] text-gray-600">${accountRows.length} Hesap Bulundu</span>
        </div>
        <div class="overflow-x-auto">
          <table class="sap-alv">
            <thead><tr><th>G/L Hesabı</th><th style="text-align:right;">Kalem Sayısı</th><th style="text-align:right;">Borç Toplamı</th><th style="text-align:right;">Alacak Toplamı</th><th style="text-align:right;">Bakiye</th></tr></thead>
            <tbody>${accountRows.map(r => `<tr><td>${r.HKONT}</td><td style="text-align:right;">${r.KALEM}</td><td style="text-align:right;">${r.BORC}</td><td style="text-align:right;">${r.ALACAK}</td><td style="text-align:right;font-weight:bold;">${r.BAKIYE}</td></tr>`).join('')}</tbody>
          </table>
        </div>
      </div>
    `;

    if (!completedLessons.has(13)) {
      completedLessons.add(13);
      xp += 50;
      saveProgress();
      updateProgressUI();
      updateDbSummary();
      resDiv.innerHTML += `<div class="text-gold font-pixel text-xs mt-4 block text-center bg-panel2 p-3 pixel-corners border border-gold/30">✨ TEBRİKLER! +50 SAP PUANI! ✨</div>`;
      document.getElementById('next-btn').classList.remove('hidden');
    }
  }

  function nextLesson() {
    const idx = lessonsData.findIndex(l => l.id === currentLesson);
    if (idx >= 0 && idx < lessonsData.length - 1) openLesson(lessonsData[idx + 1].id);
  }

  window.onload = () => {
    loadProgress();
    renderLessons();
    updateProgressUI();
    updateDbSummary();
  };
</script>

