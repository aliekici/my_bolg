  /* ============================= PERSISTENCE ============================= */
  function saveProgress() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ xp, completedList: Array.from(completedLessons), db, counters }));
  }

  function loadProgress() {
    const savedData = localStorage.getItem(STORAGE_KEY);
    if (savedData) {
      try {
        const parsed = JSON.parse(savedData);
        xp = parsed.xp || 0;
        completedLessons = new Set(parsed.completedList || []);
        if (parsed.db) db = Object.assign(defaultDB(), parsed.db);
        if (parsed.counters) counters = Object.assign(defaultCounters(), parsed.counters);
      } catch (e) {
        console.error("Progress yüklenirken hata oluştu:", e);
      }
    }
  }

  function updateProgressUI() {
    document.getElementById('xp-text').innerText = `${xp} / ${lessonsData.length * 50}`;
    document.getElementById('ex-text').innerText = `${completedLessons.size} / ${lessonsData.length}`;
    document.getElementById('progress-bar').style.width = `${(completedLessons.size / lessonsData.length) * 100}%`;

    completedLessons.forEach(id => {
      const btn = document.getElementById('btn-lesson-' + id);
      if (btn) {
        btn.classList.remove('bg-sapBlue', 'text-white');
        btn.classList.add('bg-panel2', 'text-sapBlue', 'border', 'border-sapBlue/50');
        btn.innerHTML = 'Tamamlandı <i class="fa-solid fa-check ml-1"></i>';
      }
    });
  }

  function updateDbSummary() {
    const el = document.getElementById('db-summary');
    el.innerHTML = Object.keys(TABLE_META).map(t =>
      `<div class="flex justify-between"><span>${t}</span><span class="text-neonBlue font-semibold">${(db[t] || []).length} satır</span></div>`
    ).join('');
  }

  function resetProgress() {
    if (confirm("Tüm eğitim ilerlemeni ve ürettiğin verileri sıfırlamak istediğine emin misin?")) {
      localStorage.removeItem(STORAGE_KEY);
      location.reload();
    }
  }

  /* ============================= LIST RENDER ============================= */
  function renderLessons() {
    [1, 2, 3].forEach(chapterId => {
      const container = document.getElementById(`chapter-${chapterId}-container`);
      container.innerHTML = "";
      const chapterLessons = lessonsData.filter(l => l.ch === chapterId);
      chapterLessons.forEach(lesson => {
        container.innerHTML += `
          <div class="exercise-row flex items-center justify-between px-5 py-4 transition-colors border-b border-border" onclick="openLesson(${lesson.id})">
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 flex items-center justify-center text-xs font-bold text-sapBlue border border-sapBlue/40 pixel-corners">${lesson.id}</span>
              <span class="text-sm text-gray-200">${lesson.name}</span>
            </div>
            <button id="btn-lesson-${lesson.id}" class="btn-pixel-blue bg-sapBlue text-white font-bold text-xs px-4 py-1.5 pixel-corners hover:brightness-110">Seç</button>
          </div>
        `;
      });
    });
  }

  /* ============================= MODAL / LESSON FLOW ============================= */
  function openLesson(id) {
    currentLesson = id;
    const lesson = lessonsData.find(l => l.id === id);
    document.getElementById('lesson-title').innerText = lesson.title;
    document.getElementById('lesson-number-badge').innerText = id;
    document.getElementById('lesson-content').innerHTML = lesson.content;

    const editor = document.getElementById('sql-editor');
    editor.value = "";
    checkLiveCode();

    document.getElementById('console-output').innerHTML = '<span class="text-gray-500 font-mono">> SAP Sistemine Bağlanıldı (Client 100). Komut Bekleniyor...</span>';
    document.getElementById('next-btn').classList.add('hidden');
    document.getElementById('lesson-modal').classList.add('active');
    document.body.style.overflow = "hidden";

    setTimeout(() => editor.focus(), 100);
  }

  function closeLesson() {
    document.getElementById('lesson-modal').classList.remove('active');
    document.body.style.overflow = "auto";
  }

  function checkLiveCode() {
    const editor = document.getElementById('sql-editor');
    const container = document.getElementById('editor-container');
    const codeUpper = editor.value.toUpperCase().trim();
    const lesson = lessonsData.find(l => l.id === currentLesson);

    if (codeUpper.length === 0) {
      container.style.borderColor = '#232f46';
      container.style.boxShadow = 'none';
    } else if (lesson.validation(codeUpper)) {
      container.style.borderColor = '#39ff88';
      container.style.boxShadow = '0 0 12px rgba(57,255,136,0.55)';
    } else {
      container.style.borderColor = '#ff5fa2';
      container.style.boxShadow = '0 0 8px rgba(255,95,162,0.3)';
    }
  }

  function showHint() {
    const lesson = lessonsData.find(l => l.id === currentLesson);
    const editor = document.getElementById('sql-editor');
    editor.value = lesson.answer;
    checkLiveCode();

    document.getElementById('console-output').innerHTML = `
      <span class="text-gold font-mono block">> 💡 Sistem İpucu: İşlem kodu komut satırına eklendi.</span>
      <span class="text-gray-500 font-mono">> Ekranı açmak için "Enter" tuşuna basabilirsin.</span>
    `;
  }

  function handleEnter(e) {
    if (e.key === 'Enter') runCode();
  }

  function runCode() {
    const codeRaw = document.getElementById('sql-editor').value;
    const codeUpper = codeRaw.toUpperCase().trim();
    const consoleOut = document.getElementById('console-output');
    const lesson = lessonsData.find(l => l.id === currentLesson);

    if (codeRaw.trim().length < 2) {
      consoleOut.innerHTML = `<span class="text-neonPink font-mono">> Lütfen geçerli bir işlem kodu (T-Code) girin.</span>`;
      return;
    }

    if (!lesson.validation(codeUpper)) {
      consoleOut.innerHTML = `
        <span class="text-neonPink block font-mono font-bold">> [ HATA ] "${codeUpper}" işlemi bu senaryo için uygun değil veya yetkiniz yok.</span>
        <div class="mt-3 p-3 bg-panel border border-border pixel-corners font-sans text-sm text-gray-400">
           Lütfen talimatlarda istenen doğru T-Code değerini girdiğinizden emin olun. (Başına /n koymayı deneyebilirsiniz)
        </div>`;
      return;
    }

    if (lesson.isSE16N) { renderSE16NScreen(); return; }
    if (lesson.isStockOverview) { renderStockOverviewScreen(); return; }
    if (lesson.isGLBalance) { renderGLBalanceScreen(); return; }
    renderTransactionScreen(lesson);
  }

  /* ============================= FIELD / FORM RENDERING ============================= */
  function fieldHTML(f) {
    const idAttr = `tf-${f.id}`;
    let inputHtml = '';
    let hint = '';
    if (f.type === 'text') {
      inputHtml = `<input type="text" id="${idAttr}" placeholder="${f.placeholder || ''}" class="sap-field-input" />`;
    } else if (f.type === 'number') {
      inputHtml = `<input type="number" step="any" id="${idAttr}" placeholder="${f.placeholder || ''}" class="sap-field-input" />`;
    } else if (f.type === 'date') {
      inputHtml = `<input type="date" id="${idAttr}" value="${f.default || todayStr()}" class="sap-field-input" />`;
    } else if (f.type === 'select') {
      const opts = f.options.map(o => `<option value="${o.v}" ${f.default === o.v ? 'selected' : ''}>${o.t}</option>`).join('');
      inputHtml = `<select id="${idAttr}" class="sap-field-input">${opts}</select>`;
    } else if (f.type === 'ref') {
      const rows = db[f.sourceTable] || [];
      const seen = new Set(); const uniqueRows = [];
      rows.forEach(r => { if (!seen.has(r[f.valueField])) { seen.add(r[f.valueField]); uniqueRows.push(r); } });
      let opts = `<option value="">-- Seçiniz --</option>` + uniqueRows.map(r => `<option value="${r[f.valueField]}">${f.display(r)}</option>`).join('');
      inputHtml = `<select id="${idAttr}" class="sap-field-input">${opts}</select>`;
      if (uniqueRows.length === 0) {
        hint = `<div class="text-[#b30000] text-[11px] mt-1"><i class="fa-solid fa-triangle-exclamation"></i> ${f.emptyHint || 'Önce ilgili kaydı oluşturmalısınız.'}</div>`;
      }
    }
    return `<div class="flex flex-col gap-0.5 ${f.required ? 'sap-field-required' : ''}">
      <label class="sap-field-label">${f.label}${f.required ? ' <span class="sap-required-mark">*</span>' : ''}</label>
      ${inputHtml}
      ${hint}
    </div>`;
  }

  function renderTransactionScreen(lesson) {
    const consoleOut = document.getElementById('console-output');
    let tabsHtml = '';
    let contentHtml = '';
    lesson.tabs.forEach((tab, idx) => {
      tabsHtml += `<div onclick="switchTab(${idx})" id="tab-btn-${idx}" class="sap-tab ${idx === 0 ? 'active' : ''}">${tab.label}</div>`;
      contentHtml += `<div id="tab-content-${idx}" class="sap-groupbox ${idx === 0 ? '' : 'hidden'}">
          <span class="gb-label">${tab.label}</span>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-1">${tab.fields.map(fieldHTML).join('')}</div>
        </div>`;
    });

    consoleOut.innerHTML = `
      <div class="sap-window pixel-corners overflow-hidden">
        <div class="sap-titlebar">
          <span><i class="fa-regular fa-window-maximize mr-1"></i> ${lesson.title}</span>
          <div class="sap-title-icons">
            <span class="win-btn">_</span><span class="win-btn">&#9633;</span><span class="win-btn">&times;</span>
          </div>
        </div>
        <div class="sap-menubar">
          <span>Sistem</span><span>Düzenle</span><span>Görüntüle</span><span>Ayarlar</span><span>Ortam</span><span>Yardım</span>
        </div>
        <div class="sap-toolbar">
          <button type="button" class="sap-tool-btn" onclick="saveTransaction()" title="Kaydet (Ctrl+S)"><i class="fa-solid fa-floppy-disk"></i></button>
          <div class="sap-tool-sep"></div>
          <button type="button" class="sap-tool-btn" title="Geri"><i class="fa-solid fa-arrow-left"></i></button>
          <button type="button" class="sap-tool-btn" title="Çık"><i class="fa-solid fa-door-open"></i></button>
          <div class="sap-tool-sep"></div>
          <button type="button" class="sap-tool-btn" title="Yazdır"><i class="fa-solid fa-print"></i></button>
          <button type="button" class="sap-tool-btn" title="Bul"><i class="fa-solid fa-magnifying-glass"></i></button>
          <span class="text-[10px] text-gray-600 ml-auto pr-2 whitespace-nowrap">Client 100 / EĞİTİM</span>
        </div>
        <div class="sap-tabstrip">${tabsHtml}</div>
        <div class="sap-body">
          <div id="tab-contents-wrap">${contentHtml}</div>
          <div class="flex justify-end">
            <button onclick="saveTransaction()" class="sap-btn flex items-center gap-2">
              <i class="fa-solid fa-floppy-disk"></i> Kaydet (Ctrl+S)
            </button>
          </div>
        </div>
        <div class="sap-statusbar">
          <i class="fa-regular fa-circle text-gray-400"></i>
          <span>Giriş bekleniyor</span>
        </div>
      </div>
      <div id="result-area" class="mt-4"></div>
    `;
  }

  function switchTab(idx) {
    const lesson = lessonsData.find(l => l.id === currentLesson);
    lesson.tabs.forEach((tab, i) => {
      document.getElementById(`tab-content-${i}`).classList.toggle('hidden', i !== idx);
      document.getElementById(`tab-btn-${i}`).classList.toggle('active', i === idx);
    });
  }

  function errorCard(msg) {
    return `<div class="sap-window pixel-corners overflow-hidden">
       <div class="flex items-center gap-2 bg-[#ffe8e8] border-b border-[#c00000] text-[#900000] text-xs font-bold px-3 py-2.5">
         <i class="fa-solid fa-circle-exclamation"></i> ${msg}
       </div>
    </div>`;
  }

  function tableCardHtml(name, row) {
    const meta = TABLE_META[name];
    return `<div class="sap-window pixel-corners overflow-hidden mb-3">
       <div class="sap-titlebar" style="padding:4px 8px;">
         <span class="text-[11px]"><i class="fa-solid fa-table-cells mr-1"></i> ${name} <span class="font-normal opacity-80">— ${meta.desc}</span></span>
       </div>
       <div class="overflow-x-auto">
         <table class="sap-alv">
           <thead><tr>${meta.cols.map(c => `<th>${c}</th>`).join('')}</tr></thead>
           <tbody><tr>${meta.cols.map(c => `<td>${row[c] !== undefined && row[c] !== '' ? row[c] : '-'}</td>`).join('')}</tr></tbody>
         </table>
       </div>
    </div>`;
  }

  function saveTransaction() {
    const lesson = lessonsData.find(l => l.id === currentLesson);
    const values = {};
    lesson.tabs.forEach(tab => tab.fields.forEach(f => {
      const el = document.getElementById(`tf-${f.id}`);
      let v = el.value;
      if (f.type === 'number') v = v === '' ? null : parseFloat(v);
      values[f.id] = v;
    }));

    const missing = [];
    lesson.tabs.forEach(tab => tab.fields.forEach(f => {
      if (f.required && (values[f.id] === '' || values[f.id] === null || values[f.id] === undefined)) missing.push(f.label);
    }));

    const resultArea = document.getElementById('result-area');
    if (missing.length > 0) {
      resultArea.innerHTML = errorCard(`Lütfen zorunlu alanları doldurun: ${missing.join(', ')}`);
      return;
    }

    const res = lesson.onSave(values, db);
    if (!res.success) {
      resultArea.innerHTML = errorCard(res.message);
      return;
    }

    const tablesHtml = res.tables.map(t => tableCardHtml(t.name, t.row)).join('');
    resultArea.innerHTML = `
      <div class="sap-window pixel-corners overflow-hidden mb-3">
        <div class="flex items-center gap-2 bg-[#e3f3e3] border-b border-[#4a8f4a] text-[#1a5c1a] text-xs font-bold px-3 py-2.5">
          <i class="fa-solid fa-circle-check"></i> ${res.message}
        </div>
      </div>
      ${tablesHtml}
      <div class="text-gold font-pixel text-xs mt-4 block text-center bg-panel2 p-3 pixel-corners border border-gold/30">✨ TEBRİKLER! +50 SAP PUANI! ✨</div>
    `;

    if (!completedLessons.has(currentLesson)) {
      completedLessons.add(currentLesson);
      xp += 50;
    }
    saveProgress();
    updateProgressUI();
    updateDbSummary();
    const curIdx = lessonsData.findIndex(l => l.id === currentLesson);
    if (curIdx < lessonsData.length - 1) document.getElementById('next-btn').classList.remove('hidden');
  }

