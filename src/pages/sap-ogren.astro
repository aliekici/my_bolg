            <span class="win-btn">_</span><span class="win-btn">&#9633;</span><span class="win-btn">&times;</span>
          </div>
        </div>
        <div class="sap-menubar">
          <span>Program</span><span>Düzenle</span><span>Görüntüle</span><span>Ortam</span><span>Yardım</span>
        </div>
        <div class="sap-toolbar">
          <button type="button" class="sap-tool-btn" onclick="showStockOverview()" title="Çalıştır (F8)"><i class="fa-solid fa-play"></i></button>
          <div class="sap-tool-sep"></div>
          <button type="button" class="sap-tool-btn" title="Geri"><i class="fa-solid fa-arrow-left"></i></button>
          <button type="button" class="sap-tool-btn" title="Çık"><i class="fa-solid fa-door-open"></i></button>
