            <div class="flex gap-3 items-end flex-wrap pt-1">
              <div class="flex flex-col gap-0.5">
                <label class="sap-field-label">Fabrika</label>
                <select id="mmbe-plant" class="sap-field-input" style="min-width:220px;">
                  <option value="">-- Tümü --</option>
