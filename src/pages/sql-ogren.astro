---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!DOCTYPE html>
<html lang="tr">
<head>
    <BaseHead title={"SQL Öğren - " + SITE_TITLE} description={SITE_DESCRIPTION} />
    
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js" crossorigin="anonymous" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/alasql@4.3.3/dist/alasql.min.js" is:inline></script>

    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              pixel: ['"Press Start 2P"', 'cursive'],
              sans: ['Outfit', 'sans-serif'],
            },
            colors: {
              bg: '#0a0e1a',
              panel: '#111827',
              panel2: '#161f30',
              border: '#232f46',
              neon: '#39ff88',
              neonBlue: '#4fd6ff',
              neonPink: '#ff5fa2',
              gold: '#ffc84a',
            },
            boxShadow: {
              pixel: '4px 4px 0px 0px rgba(0,0,0,0.5)',
              neon: '0 0 12px rgba(57,255,136,0.55)',
              neonPink: '0 0 12px rgba(255,95,162,0.55)',
            },
          },
        },
      };
    </script>

    <style is:global>
      body {
        background-color: #0a0e1a;
        background-image: radial-gradient(circle at 15% 10%, rgba(57,255,136,0.08), transparent 35%), radial-gradient(circle at 85% 0%, rgba(79,214,255,0.08), transparent 35%);
        color: #e5e7eb;
      }
      #lesson-content code {
        background-color: #161f30;
        color: #39ff88;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: 'Courier New', Courier, monospace;
        border: 1px solid #232f46;
      }
      .pixel-corners {
        clip-path: polygon(0px 8px, 8px 8px, 8px 0px, calc(100% - 8px) 0px, calc(100% - 8px) 8px, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 8px calc(100% - 8px), 0px calc(100% - 8px));
      }
      .btn-pixel { box-shadow: 4px 4px 0px 0px #04321a; transition: transform 0.08s ease, box-shadow 0.08s ease; }
      .btn-pixel-gold { box-shadow: 4px 4px 0px 0px #664d00; transition: transform 0.08s ease, box-shadow 0.08s ease; }
      .btn-pixel:active, .btn-pixel-gold:active { transform: translate(4px, 4px); box-shadow: 0px 0px 0px 0px transparent; }
      .scanline-badge { background-image: repeating-linear-gradient(45deg, rgba(57,255,136,0.12) 0px, rgba(57,255,136,0.12) 2px, transparent 2px, transparent 6px); }
      ::-webkit-scrollbar { width: 10px; }
      ::-webkit-scrollbar-track { background: #0a0e1a; }
      ::-webkit-scrollbar-thumb { background: #232f46; border-radius: 8px; }
      .glow-text { text-shadow: 0 0 10px rgba(57,255,136,0.6); }
      .exercise-row:hover { background-color: #1b2436; }
      .modal-overlay { display: none; }
      .modal-overlay.active { display: flex; }
      .code-editor { font-family: 'Courier New', Courier, monospace; }
      table th { position: sticky; top: 0; }
      #editor-container { transition: box-shadow 0.3s ease, border-color 0.3s ease; }
    </style>
</head>

<body class="bg-bg text-gray-200 font-sans antialiased">
    <Header />
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <section class="pt-10 pb-10">
            <h1 class="font-pixel text-5xl text-white glow-text mb-4">SQL</h1>
            <p class="text-gray-400">İlerlemen artık tarayıcında saklanıyor.</p>
        </section>
        <div id="chapter-1-container"></div>
        <div id="chapter-2-container"></div>
        <div id="chapter-3-container"></div>
        <div id="chapter-4-container"></div>
    </main>
    <div id="lesson-modal" class="modal-overlay fixed inset-0 z-[100] bg-bg/95 p-6">
        </div>
    <Footer />
    <script is:inline>
        // JS Kodlarını buraya eklemeye devam edebilirsin
    </script>
</body>
</html>