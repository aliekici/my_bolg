---
// src/pages/kategori/sap.astro
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<html lang="tr">
<head>
    <BaseHead title={`SAP Veri Ekosistemi | ${SITE_TITLE}`} description="SAP ERP veri mimarisi, tablolar ve veri küpleri üzerine rehberler." />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Kategori Sayfalarına Özel Stiller */
        :root {
            --bg-dark: #0a0e17; 
            --bg-darker: #02060f;
            --text-main: #f0f6fc;
            --text-muted: #8b949e;
            --border-color: #30363d;
            --sap-color: #3b82f6; /* SAP Mavi Tema */
        }
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-dark); color: var(--text-main); margin: 0; }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
        
        .hub-header { padding: 80px 0 60px; text-align: center; border-bottom: 1px solid var(--border-color); background: radial-gradient(circle at top, rgba(59, 130, 246, 0.1), var(--bg-dark) 70%); }
        .hub-icon { font-size: 3.5rem; color: var(--sap-color); margin-bottom: 20px; }
        .hub-header h1 { font-size: 2.8rem; font-weight: 700; margin-bottom: 15px; }
        .hub-header p { color: var(--text-muted); font-size: 1.15rem; max-width: 600px; margin: 0 auto; }
        
        .content-section { padding: 60px 0; }
        .section-title { font-size: 1.5rem; margin-bottom: 30px; border-left: 4px solid var(--sap-color); padding-left: 15px; }
        
        .grid-layout { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        
        .hub-card { background-color: #0d1117; border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; transition: all 0.3s; display: flex; flex-direction: column; }
        .hub-card:hover { transform: translateY(-5px); border-color: var(--sap-color); box-shadow: 0 10px 30px rgba(59, 130, 246, 0.1); }
        .card-tag { font-size: 0.75rem; background: rgba(59, 130, 246, 0.2); color: var(--sap-color); padding: 4px 10px; border-radius: 12px; align-self: flex-start; margin-bottom: 15px; font-weight: 600; }
        .hub-card h3 { font-size: 1.25rem; margin: 0 0 10px 0; line-height: 1.4; }
        .hub-card p { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px; flex: 1; }
        .hub-card a { color: var(--sap-color); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px; transition: gap 0.2s; }
        .hub-card a:hover { gap: 12px; }
    </style>
</head>
<body>
    <Header />
    
    <main>
        <header class="hub-header">
            <div class="container">
                <i class="fa-solid fa-cube hub-icon"></i>
                <h1>SAP Ekosistemi</h1>
                <p>ERP mimarisini çözümleyin, kritik tablolar arası ilişkileri öğrenin ve şirket verilerini analitik süreçlere hazırlayın.</p>
            </div>
        </header>

        <section class="content-section">
            <div class="container">
                <h2 class="section-title">Rehberler ve Pratikler</h2>
                <div class="grid-layout">
                    
                    <article class="hub-card">
                        <span class="card-tag">Veri Modelleme</span>
                        <h3>SAP Sistemlerinde Kendi Veri Küplerinizi Oluşturma Rehberi</h3>
                        <p>Analiz süreçlerini hızlandırmak için SAP üzerinde kendi veri küplerinizi (Cube) nasıl kurgulayacağınızı ve SSAS ile nasıl entegre edeceğinizi adım adım inceleyelim.</p>
                        <a href="#">Makaleyi Oku <i class="fa-solid fa-arrow-right"></i></a>
                    </article>

                    <article class="hub-card">
                        <span class="card-tag">Mimari</span>
                        <h3>SD ve MM Modüllerinin Veri Anatomisi</h3>
                        <p>Satış ve Dağıtım (SD) ile Malzeme Yönetimi (MM) süreçlerinde verinin hangi tablolardan akarak finansal sonuçlara (FI) bağlandığını keşfedin.</p>
                        <a href="#">Makaleyi Oku <i class="fa-solid fa-arrow-right"></i></a>
                    </article>

                    <article class="hub-card" style="opacity: 0.7;">
                        <span class="card-tag" style="background: #1f2937; color: #9ca3af;">İnteraktif</span>
                        <h3>SAP Modül Simülasyonu</h3>
                        <p>Sanal bir SAP ortamında kod yazarak tablolar arası join (birleştirme) işlemlerini test edebileceğiniz interaktif laboratuvar ortamı.</p>
                        <a href="#" style="color: #9ca3af; cursor: not-allowed;"><i class="fa-solid fa-clock"></i> Çok Yakında</a>
                    </article>

                </div>
            </div>
        </section>
    </main>

    <Footer />
</body>
</html>