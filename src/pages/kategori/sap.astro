---
// src/pages/kategori/sap.astro
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

// --- OTOMATİK YAZI ÇEKME ---
const allPosts = await getCollection('blog');

const sapPosts = allPosts
    .filter((post) => post.id.startsWith('sap-'))
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

function detectModule(id: string) {
    if (id.includes('-fi-mm-sd-') || id.includes('entegrasyon')) {
        return { module: 'pipeline', moduleLabel: 'FI+MM+SD Entegrasyon' };
    }
    if (id.includes('-fi-')) {
        return { module: 'fi', moduleLabel: 'FI · Finansal Muhasebe' };
    }
    if (id.includes('-mm-')) {
        return { module: 'mm', moduleLabel: 'MM · Malzeme Yönetimi' };
    }
    if (id.includes('-sd-')) {
        return { module: 'sd', moduleLabel: 'SD · Satış ve Dağıtım' };
    }
    return { module: 'ref', moduleLabel: 'Referans' };
}

const records = sapPosts.map((post, index) => {
    const match = post.id.match(/dersleri-(\d+)-/);
    const num = match ? match[1] : String(index + 1).padStart(2, '0');
    return {
        code: `REC-${String(num).padStart(2, '0')}`,
        href: `/blog/${post.id}`,
        title: post.data.title,
        desc: post.data.description,
        ...detectModule(post.id),
    };
});

const mmRecords = records.filter(r => r.module === 'mm');
const sdRecords = records.filter(r => r.module === 'sd');
const fiRecords = records.filter(r => r.module === 'fi');
const otherRecords = records.filter(r => r.module === 'pipeline' || r.module === 'ref');
---

<html lang="tr">
<head>
    <BaseHead title={`SAP Veri Ekosistemi | ${SITE_TITLE}`} description="SAP ERP veri mimarisi, tablolar ve veri küpleri üzerine rehberler." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg: #0a0f1a;
            --bg-panel: #0f1626;
            --grid-line: rgba(148, 163, 184, 0.07);
            --panel-border: rgba(148, 163, 184, 0.14);
            --text-main: #edf1f7;
            --text-muted: #8b96a8;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --fi: #5b9bff;
            --mm: #34d399;
            --sd: #f472b6;
            --pipeline: #ffb454;
        }

        * { box-sizing: border-box; }

        body {
            font-family: var(--font-body);
            background-color: var(--bg);
            background-image:
                linear-gradient(var(--grid-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
            background-size: 42px 42px;
            color: var(--text-main);
            margin: 0;
            width: 100%;
            overflow-x: hidden;
        }

        a { color: inherit; text-decoration: none; }

        /* Konteyner tamamen esnek ve tam genişlik yapıldı */
        .container { width: 100%; max-width: 100%; margin: 0 auto; padding: 0 4vw; }

        /* ---------- HERO ---------- */
        .hub-header {
            padding: 96px 0 64px;
            border-bottom: 1px solid var(--panel-border);
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 4rem;
            align-items: center;
        }

        .eyebrow {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--pipeline);
            display: flex;
            align-items: center;
            gap: 0.6em;
            margin-bottom: 1.2em;
        }

        .eyebrow::before {
            content: '';
            width: 22px;
            height: 1px;
            background: var(--pipeline);
            display: inline-block;
        }

        .hub-header h1 {
            font-family: var(--font-display);
            font-size: clamp(2rem, 3.5vw, 2.8rem);
            font-weight: 700;
            line-height: 1.15;
            margin: 0 0 0.6em 0;
        }

        .hub-header p {
            color: var(--text-muted);
            font-size: 1.05rem;
            line-height: 1.65;
            max-width: 60ch;
            margin: 0;
        }

        .module-legend {
            display: flex;
            gap: 1.4rem;
            margin-top: 1.8rem;
            flex-wrap: wrap;
        }

        .module-legend span {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--text-muted);
            display: inline-flex;
            align-items: center;
            gap: 0.5em;
        }

        .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
        .dot.fi { background: var(--fi); }
        .dot.mm { background: var(--mm); }
        .dot.sd { background: var(--sd); }

        /* ---------- DYNAMIC ERP NETWORK ---------- */
        .network-panel {
            background: var(--bg-panel);
            border: 1px solid var(--panel-border);
            border-radius: 14px;
            padding: 3rem 2rem;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .network-node {
            position: relative;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1.1rem;
            z-index: 2;
            background: var(--bg);
        }

        .network-node.mm { color: var(--mm); border: 2px solid var(--mm); box-shadow: 0 0 20px rgba(52, 211, 153, 0.2); }
        .network-node.sd { color: var(--sd); border: 2px solid var(--sd); box-shadow: 0 0 20px rgba(244, 114, 182, 0.2); }
        .network-node.fi { color: var(--fi); border: 2px solid var(--fi); box-shadow: 0 0 20px rgba(91, 155, 255, 0.2); }

        .network-path {
            position: absolute;
            top: 50%;
            left: 15%;
            right: 15%;
            height: 2px;
            background: rgba(148, 163, 184, 0.2);
            z-index: 1;
            transform: translateY(-50%);
        }

        .network-packet {
            position: absolute;
            top: -4px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--pipeline);
            box-shadow: 0 0 10px var(--pipeline);
        }

        .packet-1 { animation: flowRight 3s linear infinite; }
        .packet-2 { animation: flowLeft 4s linear infinite 1s; background: var(--fi); box-shadow: 0 0 10px var(--fi); }

        @keyframes flowRight {
            0% { left: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { left: 100%; opacity: 0; }
        }

        @keyframes flowLeft {
            0% { left: 100%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { left: 0%; opacity: 0; }
        }

        .network-label {
            position: absolute;
            bottom: 15px;
            left: 0;
            width: 100%;
            text-align: center;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        @media (max-width: 900px) {
            .hero-grid { grid-template-columns: 1fr; }
        }

        /* ---------- SIMULATION BANNER ---------- */
        .sim-banner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            background: linear-gradient(120deg, rgba(255, 180, 84, 0.14), rgba(255, 180, 84, 0.03));
            border: 1px solid rgba(255, 180, 84, 0.4);
            border-radius: 14px;
            padding: 1.6rem 2rem;
            margin-top: 40px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s ease, transform 0.2s ease;
        }

        .sim-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 0% 50%, rgba(255, 180, 84, 0.18), transparent 60%);
            pointer-events: none;
        }

        .sim-banner:hover {
            border-color: var(--pipeline);
            transform: translateY(-2px);
        }

        .sim-banner-left { display: flex; align-items: center; gap: 1.3rem; }

        .sim-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: rgba(255, 180, 84, 0.16);
            border: 1px solid rgba(255, 180, 84, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--pipeline);
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .sim-badge {
            font-family: var(--font-mono);
            font-size: 0.72rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--pipeline);
            display: block;
            margin-bottom: 0.35em;
        }

        .sim-text h3 {
            font-family: var(--font-display);
            font-size: 1.2rem;
            margin: 0 0 0.3em 0;
            color: var(--text-main);
        }

        .sim-text p { margin: 0; font-size: 0.92rem; color: var(--text-muted); max-width: 60ch; }

        .sim-cta {
            font-family: var(--font-mono);
            font-size: 0.85rem;
            color: var(--pipeline);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.5em;
        }

        @media (max-width: 700px) {
            .sim-banner { flex-direction: column; align-items: flex-start; }
            .sim-cta { align-self: flex-start; }
        }

        /* ---------- SIDE-BY-SIDE MODULES LAYOUT (TAM EKRAN) ---------- */
        .content-section { padding: 60px 0 100px; }

        .main-title-area {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            border-bottom: 1px solid var(--panel-border);
            padding-bottom: 1rem;
            margin-bottom: 3rem;
        }

        .main-title-area h2 {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .main-title-area span {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        /* Tam ekran esnek 3 sütunlu yapı */
        .modules-master-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            align-items: start;
            width: 100%;
            margin-bottom: 4rem;
        }

        @media (max-width: 1024px) {
            .modules-master-grid {
                grid-template-columns: 1fr;
            }
        }

        .module-column {
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .module-group-header {
            font-family: var(--font-mono);
            font-size: 0.95rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding-bottom: 0.8rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .module-group-header::before {
            content: '';
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
        }

        .module-group-header.mm { border-color: rgba(52, 211, 153, 0.2); color: var(--mm); }
        .module-group-header.mm::before { background: var(--mm); }

        .module-group-header.sd { border-color: rgba(244, 114, 182, 0.2); color: var(--sd); }
        .module-group-header.sd::before { background: var(--sd); }

        .module-group-header.fi { border-color: rgba(91, 155, 255, 0.2); color: var(--fi); }
        .module-group-header.fi::before { background: var(--fi); }

        .cards-stack {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            list-style: none;
            margin: 0;
            padding: 0;
            width: 100%;
        }

        .record {
            background: var(--bg-panel);
            border: 1px solid var(--panel-border);
            border-left: 3px solid var(--row-color, var(--panel-border));
            border-radius: 10px;
            width: 100%;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .record.fi { --row-color: var(--fi); }
        .record.mm { --row-color: var(--mm); }
        .record.sd { --row-color: var(--sd); }
        .record.pipeline { --row-color: var(--pipeline); }
        .record.ref { --row-color: #c0c6cf; }

        .record:hover, .record:focus-within {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            border-color: var(--row-color);
        }

        .record-link {
            padding: 1.4rem;
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }

        .record-code {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            display: inline-block;
        }

        .record-body h3 {
            font-family: var(--font-display);
            font-size: 1.05rem;
            font-weight: 600;
            margin: 0 0 0.5em 0;
            color: var(--text-main);
            line-height: 1.4;
        }

        .record-body p {
            font-size: 0.88rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .empty-notice {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-family: var(--font-mono);
            padding: 1rem;
            background: rgba(148, 163, 184, 0.03);
            border-radius: 8px;
            border: 1px dashed var(--panel-border);
        }

        /* OTHER SECTION */
        .other-section-wrapper {
            margin-top: 3rem;
            border-top: 1px solid var(--panel-border);
            padding-top: 2.5rem;
            width: 100%;
        }

        .other-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
            list-style: none;
            margin: 0;
            padding: 0;
            width: 100%;
        }
    </style>
</head>
<body>
    <Header />

    <main>
        <header class="hub-header">
            <div class="container">
                <div class="hero-grid">
                    <div>
                        <p class="eyebrow">ERP Veri Ekosistemi</p>
                        <h1>SAP verisini okumayı,<br />sonra hikâyeye çevirmeyi öğrenin.</h1>
                        <p>
                            FI, MM ve SD modüllerinin verisi nasıl doğar, hangi tablolardan akar ve analitik bir içgörüye nasıl dönüşür — bu seri bunu adım adım anlatıyor.
                        </p>
                        <div class="module-legend">
                            <span><i class="dot mm"></i> MM — Malzeme</span>
                            <span><i class="dot sd"></i> SD — Satış</span>
                            <span><i class="dot fi"></i> FI — Finans</span>
                        </div>
                    </div>

                    <div class="network-panel" aria-hidden="true">
                        <div class="network-path">
                            <div class="network-packet packet-1"></div>
                            <div class="network-packet packet-2"></div>
                        </div>
                        <div class="network-node mm">MM</div>
                        <div class="network-node sd">SD</div>
                        <div class="network-node fi">FI</div>
                        <div class="network-label">Gerçek Zamanlı Modül Entegrasyonu</div>
                    </div>
                </div>

                <a class="sim-banner" href="/sap-ogren" aria-label="SAP Modül Simülasyonu — interaktif laboratuvara git">
                    <div class="sim-banner-left">
                        <div class="sim-icon" aria-hidden="true"><i class="fa-solid fa-flask"></i></div>
                        <div class="sim-text">
                            <span class="sim-badge">İnteraktif · Şimdi Aktif</span>
                            <h3>SAP Modül Simülasyonu</h3>
                            <p>Sanal bir SAP ortamında tablolar arası join işlemlerini test edebileceğiniz interaktif laboratuvar.</p>
                        </div>
                    </div>
                    <span class="sim-cta" aria-hidden="true">Laboratuvara git <i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
        </header>

        <section class="content-section">
            <div class="container">
                <div class="main-title-area">
                    <h2>SAP Modül Dersleri</h2>
                    <span>Toplam {records.length} kayıt</span>
                </div>

                {records.length === 0 ? (
                    <p class="empty-notice">Henüz bu kategoride bir yazı yok. src/content/blog/ altına slug'ı "sap-" ile başlayan bir dosya ekleyin.</p>
                ) : (
                    <>
                        <!-- MM, SD, FI SIDE BY SIDE COLUMNS (TAM GENİŞLİK) -->
                        <div class="modules-master-grid">
                            <!-- MM COLUMN -->
                            <div class="module-column">
                                <h3 class="module-group-header mm">MM · Malzeme Yönetimi</h3>
                                {mmRecords.length > 0 ? (
                                    <ul class="cards-stack">
                                        {mmRecords.map((post) => (
                                            <li class={`record ${post.module}`}>
                                                <a class="record-link" href={post.href}>
                                                    <span class="record-code">{post.code}</span>
                                                    <div class="record-body">
                                                        <h3>{post.title}</h3>
                                                        <p>{post.desc}</p>
                                                    </div>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                ) : (
                                    <p class="empty-notice">Bu modülde henüz içerik yok.</p>
                                )}
                            </div>

                            <!-- SD COLUMN -->
                            <div class="module-column">
                                <h3 class="module-group-header sd">SD · Satış ve Dağıtım</h3>
                                {sdRecords.length > 0 ? (
                                    <ul class="cards-stack">
                                        {sdRecords.map((post) => (
                                            <li class={`record ${post.module}`}>
                                                <a class="record-link" href={post.href}>
                                                    <span class="record-code">{post.code}</span>
                                                    <div class="record-body">
                                                        <h3>{post.title}</h3>
                                                        <p>{post.desc}</p>
                                                    </div>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                ) : (
                                    <p class="empty-notice">Bu modülde henüz içerik yok.</p>
                                )}
                            </div>

                            <!-- FI COLUMN -->
                            <div class="module-column">
                                <h3 class="module-group-header fi">FI · Finansal Muhasebe</h3>
                                {fiRecords.length > 0 ? (
                                    <ul class="cards-stack">
                                        {fiRecords.map((post) => (
                                            <li class={`record ${post.module}`}>
                                                <a class="record-link" href={post.href}>
                                                    <span class="record-code">{post.code}</span>
                                                    <div class="record-body">
                                                        <h3>{post.title}</h3>
                                                        <p>{post.desc}</p>
                                                    </div>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                ) : (
                                    <p class="empty-notice">Bu modülde henüz içerik yok.</p>
                                )}
                            </div>
                        </div>

                        <!-- OTHER / INTEGRATION SECTION -->
                        {otherRecords.length > 0 && (
                            <div class="other-section-wrapper">
                                <h3 class="module-group-header pipeline" style="margin-bottom: 1.5rem;">Entegrasyon & Referanslar</h3>
                                <ul class="other-grid">
                                    {otherRecords.map((post) => (
                                        <li class={`record ${post.module}`}>
                                            <a class="record-link" href={post.href}>
                                                <span class="record-code">{post.moduleLabel} · {post.code}</span>
                                                <div class="record-body">
                                                    <h3>{post.title}</h3>
                                                    <p>{post.desc}</p>
                                                </div>
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </>
                )}
            </div>
        </section>
    </main>

    <Footer />
</body>
</html>